{
  "name": "bit-cms",
  "version": "1.0.0",
  "description": "Bhagwant Institute of Technology - College Management System",
  "main": "server/production.js",
  "scripts": {
    "start": "node server/production.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client/web && npm start",
    "build": "cd client/web && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "deploy": "chmod +x deploy.sh && ./deploy.sh",
    "deploy:ssl": "./deploy.sh --ssl",
    "deploy:monitoring": "./deploy.sh --ssl --monitoring",
    "backup": "./deploy.sh --backup",
    "health": "./deploy.sh --health",
    "docker:build": "docker build -t bit-cms .",
    "docker:run": "docker-compose up",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v && docker system prune -f"
  },
  "keywords": [
    "college",
    "management",
    "system",
    "education",
    "cms",
    "nodejs",
    "react",
    "socket.io",
    "mongodb"
  ],
  "author": "BIT Development Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "cloudinary": "^1.41.0",
    "joi": "^17.11.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "express-validator": "^7.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.0",
    "@types/node": "^20.9.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/bit-cms.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/bit-cms/issues"
  },
  "homepage": "https://bit-cms.your-domain.com"
}
