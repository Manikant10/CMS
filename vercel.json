{
  "version": 2,
  "builds": [
    {
      "src": "server/index-vercel.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build",
        "buildCommand": "npm run build",
        "installCommand": "npm install"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index-vercel.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/web/build/$1"
    }
  ],
  "functions": {
    "server/index-vercel.js": {
      "maxDuration": 10
    }
  },
  "outputDirectory": "client/web/build",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "devCommand": "npm start",
  "framework": "create-react-app"
}
