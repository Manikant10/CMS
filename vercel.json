{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/web/$1"
    }
  ],
  "build": {
    "env": {
      "mongodb_uri": "@mongodb_uri",
      "jwt_secret": "@jwt_secret",
      "node_env": "production",
      "cors_origin": "@cors_origin"
    }
  }
}
