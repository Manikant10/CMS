{
  "version": 2,
  "rootDirectory": "client/web",
  "builds": [
    {
      "src": "../server/index-vercel.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "../server/index-vercel.js"
    },
    {
      "src": "/(.*)",
      "dest": "build/$1"
    }
  ],
  "functions": {
    "../server/index-vercel.js": {
      "maxDuration": 10
    }
  },
  "outputDirectory": "build",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "framework": "create-react-app"
}
